[Unit]
Description=Graphite Tuya (cloud) power collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/code/electricity_monitoring
ExecStart=/usr/bin/python3 -u /home/pi/code/electricity_monitoring/tuya_cloud_to_graphite.py
Restart=always
RestartSec=10
StandardOutput=append:/home/pi/electricity_tuya_cloud.log
StandardError=append:/home/pi/electricity_tuya_cloud.log

[Install]
WantedBy=multi-user.target
