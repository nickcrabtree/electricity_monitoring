[Unit]
Description=Graphite whole-house energy aggregator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/code/electricity_monitoring
ExecStart=/usr/bin/python3 -u /home/pi/code/electricity_monitoring/aggregate_energy.py
Restart=always
RestartSec=10
StandardOutput=append:/home/pi/electricity_aggregate.log
StandardError=append:/home/pi/electricity_aggregate.log

[Install]
WantedBy=multi-user.target
